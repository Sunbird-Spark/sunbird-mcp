# Sunbird Spark MCP — environment template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# Kong gateway base URL (must be https:// in non-local environments)
KONG_URL=https://your-sunbird-host.example.com/api

# Anonymous Kong token — used for public/read-only API calls
KONG_ANONYMOUS_TOKEN=<your-anonymous-jwt-token>

# Logged-in Kong token — used for authenticated write APIs (portal's KONG_LOGGEDIN_FALLBACK_TOKEN)
# Leave empty to fall back to KONG_ANONYMOUS_TOKEN
KONG_LOGGEDIN_TOKEN=

# Sunbird channel/org ID — auto-resolved from Kong if left empty
SUNBIRD_CHANNEL_ID=

# Application identifier shown in telemetry
APP_ID=local.sunbird.mcp

# Port for the MCP HTTP server
MCP_PORT=3002

# Keycloak settings — required only when tool_login_start / tool_login_poll are used
# KEYCLOAK_ISSUER_URL must be https:// in non-local environments
KEYCLOAK_ISSUER_URL=https://your-keycloak-host.example.com/auth/realms/sunbird
KEYCLOAK_CLIENT_ID=android
KEYCLOAK_CLIENT_SECRET=
